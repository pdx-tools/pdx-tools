{
  "name": "pdx.tools-root",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "format": "oxfmt --write \"**/*.{js,jsx,ts,tsx,css}\"",
    "format:check": "oxfmt --check \"**/*.{js,jsx,ts,tsx,css}\"",
    "lint": "oxlint",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "concurrently": "9.2.1",
    "wrangler": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "typescript": "catalog:"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss"
    ],
    "tailwindFunctions": [
      "cx"
    ]
  },
  "packageManager": "pnpm@10.11.0"
}
