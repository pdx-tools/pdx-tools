{
  "__inputs": [
    {
      "name": "DS_CLICKHOUSE",
      "label": "ClickHouse (Analytics Engine SQL API)",
      "description": "Altinity ClickHouse datasource pointed at the pdx_metrics Analytics Engine dataset",
      "type": "datasource",
      "pluginId": "vertamedia-clickhouse-datasource",
      "pluginName": "Altinity plugin for ClickHouse"
    },
    {
      "name": "DS_TEMPO",
      "label": "Tempo (Grafana Cloud)",
      "description": "Tempo datasource holding pdx-tools-api spans exported over OTLP from Cloud Run",
      "type": "datasource",
      "pluginId": "tempo",
      "pluginName": "Tempo"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "vertamedia-clickhouse-datasource",
      "name": "Altinity plugin for ClickHouse",
      "version": "3.0.0"
    },
    {
      "type": "datasource",
      "id": "tempo",
      "name": "Tempo",
      "version": "1.0.0"
    },
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "panel", "id": "row", "name": "Row", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Backend observability for pdx.tools. Top section: Cloudflare Analytics Engine dataset `pdx_metrics` (edge/Worker view — save-file / OG-image ops, cache, bytes; every query filters/groups on blob1, counts sample-weighted as sum(_sample_interval * double1)). Bottom 'API server spans' row: Cloud Run OTEL spans in Tempo, queried with TraceQL metrics — this is the server-side breakdown of parse/screenshot latency (e.g. screenshot.endpoint = screenshot.parse_save + pdx-map.render + pdx-map.headless.capture-viewport).",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["pdx-tools", "observability", "cloudflare", "tempo", "traces"],
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "DS_CLICKHOUSE",
        "type": "datasource",
        "query": "vertamedia-clickhouse-datasource",
        "current": {},
        "hide": 0,
        "label": "Analytics Engine"
      },
      {
        "name": "DS_TEMPO",
        "type": "datasource",
        "query": "tempo",
        "current": {},
        "hide": 0,
        "label": "Tempo"
      }
    ]
  },
  "panels": [
    {
      "title": "Save fetches",
      "type": "stat",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "table",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT sum(_sample_interval * double1) as cached FROM $table WHERE $timeFilter AND blob1 = 'save_file_get' AND blob2 = 'HIT'"
        },
        {
          "refId": "B",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "table",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT sum(_sample_interval * double1) as origin FROM $table WHERE $timeFilter AND blob1 = 'save_file_get' AND blob2 = 'MISS'"
        }
      ]
    },
