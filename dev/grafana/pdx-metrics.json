{
  "__inputs": [
    {
      "name": "DS_CLICKHOUSE",
      "label": "ClickHouse (Analytics Engine SQL API)",
      "description": "Altinity ClickHouse datasource pointed at the pdx_metrics Analytics Engine dataset",
      "type": "datasource",
      "pluginId": "vertamedia-clickhouse-datasource",
      "pluginName": "Altinity plugin for ClickHouse"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "vertamedia-clickhouse-datasource",
      "name": "Altinity plugin for ClickHouse",
      "version": "3.0.0"
    },
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Backend observability for pdx.tools save-file / OG-image / pdx-api operations. Single Cloudflare Analytics Engine dataset `pdx_metrics`; every query filters/groups on blob1 (operation). Headline stats total over the selected range; the time-series below show shape (counts as bars, latency as points) since traffic is bursty. Counts are sample-weighted: sum(_sample_interval * double1).",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["pdx-tools", "observability", "cloudflare"],
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "DS_CLICKHOUSE",
        "type": "datasource",
        "query": "vertamedia-clickhouse-datasource",
        "current": {},
        "hide": 0,
        "label": "Datasource"
      }
    ]
  },
  "panels": [
    {
      "title": "Save fetches",
      "type": "stat",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "table",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT sum(_sample_interval * double1) as cached FROM $table WHERE $timeFilter AND blob1 = 'save_file_get' AND blob2 = 'HIT'"
        },
        {
          "refId": "B",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "table",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT sum(_sample_interval * double1) as origin FROM $table WHERE $timeFilter AND blob1 = 'save_file_get' AND blob2 = 'MISS'"
        }
      ]
    },
    {
      "title": "OG fetches",
      "type": "stat",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 5, "w": 5, "x": 5, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "table",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT sum(_sample_interval * double1) as cached FROM $table WHERE $timeFilter AND blob1 = 'og_get' AND blob2 = 'HIT'"
        },
        {
          "refId": "B",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "table",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT sum(_sample_interval * double1) as origin FROM $table WHERE $timeFilter AND blob1 = 'og_get' AND blob2 != 'HIT'"
        }
      ]
    },
    {
      "title": "Errors",
      "type": "stat",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 5, "w": 4, "x": 10, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "table",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT sum(_sample_interval * double1) as errors FROM $table WHERE $timeFilter AND blob3 = 'error'"
        }
      ]
    },
    {
      "title": "Parse latency (ms)",
      "type": "stat",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 5, "w": 5, "x": 14, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "table",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT quantileWeighted(0.5)(double2, _sample_interval) as median, quantileWeighted(0.95)(double2, _sample_interval) as p95 FROM $table WHERE $timeFilter AND blob1 = 'parse_save'"
        }
      ]
    },
    {
      "title": "Screenshot latency (ms)",
      "type": "stat",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 5, "w": 5, "x": 19, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "table",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT quantileWeighted(0.5)(double2, _sample_interval) as median, quantileWeighted(0.95)(double2, _sample_interval) as p95 FROM $table WHERE $timeFilter AND blob1 = 'render_screenshot'"
        }
      ]
    },
    {
      "title": "Save fetch latency · uncached (ms)",
      "type": "stat",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "table",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT quantileWeighted(0.5)(double2, _sample_interval) as median, quantileWeighted(0.95)(double2, _sample_interval) as p95 FROM $table WHERE $timeFilter AND blob1 = 'save_file_get' AND blob2 = 'MISS'"
        }
      ]
    },
    {
      "title": "OG fetch latency · uncached (ms)",
      "type": "stat",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "table",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT quantileWeighted(0.5)(double2, _sample_interval) as median, quantileWeighted(0.95)(double2, _sample_interval) as p95 FROM $table WHERE $timeFilter AND blob1 = 'og_get' AND blob2 != 'HIT'"
        }
      ]
    },
    {
      "title": "Requests by operation (per bucket)",
      "type": "timeseries",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 1,
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "time_series",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT $timeSeries as t, blob1 as operation, sum(_sample_interval * double1) as requests FROM $table WHERE $timeFilter GROUP BY t, operation ORDER BY t"
        }
      ]
    },
    {
      "title": "p95 latency by operation (ms)",
      "type": "timeseries",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "points",
            "showPoints": "always",
            "pointSize": 7,
            "lineWidth": 0,
            "fillOpacity": 0,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "time_series",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT $timeSeries as t, blob1 as operation, quantileWeighted(0.95)(double2, _sample_interval) as p95_ms FROM $table WHERE $timeFilter GROUP BY t, operation ORDER BY t"
        }
      ]
    },
    {
      "title": "Save-file cache HIT / MISS (per bucket)",
      "type": "timeseries",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "time_series",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT $timeSeries as t, blob2 as cache_result, sum(_sample_interval * double1) as requests FROM $table WHERE $timeFilter AND blob1 = 'save_file_get' GROUP BY t, cache_result ORDER BY t"
        }
      ]
    },
    {
      "title": "OG-image cache status (per bucket)",
      "type": "timeseries",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "time_series",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT $timeSeries as t, blob2 as cache_status, sum(_sample_interval * double1) as requests FROM $table WHERE $timeFilter AND blob1 = 'og_get' GROUP BY t, cache_status ORDER BY t"
        }
      ]
    },
    {
      "title": "Bytes processed by operation (per bucket)",
      "type": "timeseries",
      "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 1,
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "vertamedia-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
          "rawQuery": true,
          "format": "time_series",
          "dateTimeType": "DATETIME",
          "dateTimeColDataType": "timestamp",
          "database": "default",
          "table": "pdx_metrics",
          "query": "SELECT $timeSeries as t, blob1 as operation, sum(_sample_interval * double3) as bytes FROM $table WHERE $timeFilter AND blob1 IN ('save_file_put','og_put','parse_save','render_screenshot') GROUP BY t, operation ORDER BY t"
        }
      ]
    }
  ]
}
